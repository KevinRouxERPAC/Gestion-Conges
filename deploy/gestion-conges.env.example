# Variables d'environnement pour Gestion Conges (production)
# Copier en gestion-conges.env et adapter les valeurs.
# Ce fichier est chargé par le service systemd.

# Obligatoire en production : clé secrète pour les sessions Flask
SECRET_KEY=changez-moi-une-cle-secrete-longue-et-aleatoire

# Recommandé en production : ne PAS recréer le schéma au démarrage.
# Le schéma est géré par Alembic (flask db upgrade). Laisser db.create_all() actif
# en prod risque de masquer une migration oubliée → divergence de schéma silencieuse.
SKIP_DB_CREATE_ALL=1

# Optionnel : SMTP pour les notifications (validation/refus de congés)
# MAIL_SERVER=smtp.example.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_DEFAULT_SENDER=conges@votredomaine.local
# En dev/test sans envoi réel : MAIL_SUPPRESS_SEND=true

# Optionnel : boîte RH entreprise. Si renseignée, reçoit un email à CHAQUE nouvelle
# demande de congé (au fil de l'eau) + le récap hebdomadaire (scripts/recap_hebdo.py).
# MAIL_RH=rh@votredomaine.local
