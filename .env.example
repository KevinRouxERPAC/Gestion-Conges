# ===============================
# Gestion-Conges - Variables env
# ===============================
#
# Copier ce fichier en `.env` (local) ou en variables système (prod/IIS).
# Ne jamais committer de secrets réels.

# --- Securite ---
# Obligatoire : cle de session Flask
# Exemple generation:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=changez-moi-avec-une-cle-longue-et-aleatoire

# --- Base de donnees ---
# Par defaut l'application utilise SQLite locale.
# Pour PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/database
DATABASE_URL=

# --- URL / Cookies ---
# Mettre https en production derriere reverse proxy/IIS TLS.
PREFERRED_URL_SCHEME=http

# --- SMTP ---
MAIL_SERVER=localhost
MAIL_PORT=25
MAIL_USE_TLS=false
MAIL_USE_SSL=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=conges@erpac.local
# En dev/test, pour desactiver l'envoi reel:
MAIL_SUPPRESS_SEND=false
# Adresse de la boite RH entreprise (optionnel):
MAIL_RH=

# --- Web Push ---
# Option 1: fournir les cles VAPID en variables
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Option 2: fournir un fichier vapid_private.pem cote serveur

# --- WSGI / hebergement ---
# Utilise par run_wsgi.py si present (sinon defaults)
HOST=127.0.0.1
PORT=5000
# HTTP_PLATFORM_PORT peut etre injecte par IIS.

# --- Script utilitaire create_admin.py (optionnel) ---
ADMIN_IDENTIFIANT=admin
ADMIN_NOM=Admin
ADMIN_PRENOM=Gestion
