{
  "name": "erpac-gestion-conges",
  "private": true,
  "scripts": {
    "build:js": "terser static/js/app.js --compress --mangle --output static/js/app.min.js",
    "build:css": "tailwindcss -i static/css/tailwind-src.css -o static/css/tailwind.css --minify",
    "watch:css": "tailwindcss -i static/css/tailwind-src.css -o static/css/tailwind.css --watch",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "tailwindcss": "^3.4.17",
    "terser": "^5.46.1"
  }
}
