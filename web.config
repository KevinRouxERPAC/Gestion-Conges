<?xml version="1.0" encoding="utf-8"?>
<!--
  Configuration IIS pour Gestion Conges (HttpPlatformHandler + Waitress).
  IMPORTANT :
  - Site en HTTPS : PREFERRED_URL_SCHEME=https (certificat requis).
  - Chemin physique du site dans IIS : ce dossier (ex. C:\Sites\Gestion-Conges).
  - Creer le dossier "logs" a la racine (droits ecriture pour le pool IIS).
  - processPath = python.exe du venv, arguments = run_wsgi.py (evite 0x8007000d avec .bat).
-->
<configuration>
  <system.webServer>
    <handlers>
      <add name="httpPlatformHandler" path="*" verb="*" modules="httpPlatformHandler" resourceType="Unspecified" />
    </handlers>
    <httpPlatform processPath="C:\Windows\System32\cmd.exe" arguments="/c C:\Sites\Gestion-Conges\run_wsgi_wrapper.cmd" stdoutLogEnabled="true" stdoutLogFile="C:\Sites\Gestion-Conges\logs\stdout.log" startupTimeLimit="90">
      <environmentVariables>
        <environmentVariable name="PYTHONUNBUFFERED" value="1" />
        <environmentVariable name="PREFERRED_URL_SCHEME" value="https" />
        <!--
          SECRET_KEY : NE PAS l'écrire ici. web.config est versionné dans git ;
          un secret en clair y serait exposé à toute personne ayant accès au dépôt.
          La définir comme variable d'environnement SYSTÈME sur le serveur IIS
          (le processus Python lancé par HttpPlatformHandler en hérite).
          Voir deploy/README-IIS.md §5 pour la commande et la rotation.
        -->
        <!-- Schéma géré par Alembic (flask db upgrade) : ne pas recréer au démarrage. -->
        <environmentVariable name="SKIP_DB_CREATE_ALL" value="1" />
      </environmentVariables>
    </httpPlatform>
  </system.webServer>
</configuration>










