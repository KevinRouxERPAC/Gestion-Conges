<?xml version="1.0" encoding="utf-8"?>
<!--
  Configuration IIS pour Gestion Conges (HttpPlatformHandler + Waitress).
  IMPORTANT :
  - Site en HTTPS : PREFERRED_URL_SCHEME=https (certificat requis).
  - Chemin physique du site dans IIS : ce dossier (ex. C:\Sites\Gestion-Conges).
  - Creer le dossier "logs" a la racine (droits ecriture pour le pool IIS).
  - processPath = python.exe du venv, arguments = run_wsgi.py (evite 0x8007000d avec .bat).
  - SECRET_KEY : remplacez la valeur ci-dessous par une cle unique generee avec :
      python -c "import secrets; print(secrets.token_urlsafe(32))"
    NE JAMAIS committer la vraie cle dans le depot Git.
-->
<configuration>
  <system.webServer>
    <handlers>
      <add name="httpPlatformHandler" path="*" verb="*" modules="httpPlatformHandler" resourceType="Unspecified" />
    </handlers>
    <!--
      Utilise un wrapper .cmd dans le dossier du site pour démarrer Waitress via le venv.
      Chemins relatifs pour éviter d'avoir à "chercher/remplacer" selon le chemin d'installation.
    -->
    <httpPlatform processPath="%SystemRoot%\System32\cmd.exe" arguments="/c run_wsgi_wrapper.cmd" stdoutLogEnabled="true" stdoutLogFile="logs\stdout.log" startupTimeLimit="90">
      <environmentVariables>
        <environmentVariable name="PYTHONUNBUFFERED" value="1" />
        <environmentVariable name="PREFERRED_URL_SCHEME" value="https" />
        <!-- Remplacer par une clé unique en production (ne pas versionner de secrets). -->
        <environmentVariable name="SECRET_KEY" value="0h-YTyppzrKxOMpUdTCCA71SG37k8oUNW7rUWk4TD-E" />
      </environmentVariables>
    </httpPlatform>
  </system.webServer>
</configuration>






